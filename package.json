{
  "name": "@isaaxite/nodelib-scaffold",
  "version": "0.0.1",
  "description": "A lightweight CLI tool for scaffolding TypeScript Node.js libraries with automated publishing. Built-in GitHub Actions workflows handle version management, multi-channel releases (beta/latest), and GitHub Releases.",
  "keywords": [
    "CLI tool",
    "scaffolding",
    "TypeScript",
    "Node.js library",
    "automated publishing"
  ],
  "homepage": "https://github.com/isaaxite/nodelib-scaffold#readme",
  "bugs": {
    "url": "https://github.com/isaaxite/nodelib-scaffold/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaaxite/nodelib-scaffold.git"
  },
  "license": "MIT",
  "author": "isaaxite",
  "main": "index.ts",
  "bin": {
    "nodelib-scaffold": "./dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "jest",
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "build:dev": "NODE_ENV=development npm run build",
    "build:prod": "NODE_ENV=production npm run build",
    "dev": "nodemon --watch index.ts -e ts --exec \"npm run build:dev\"",
    "check-publish": "npm pack --dry-run",
    "publish:beta": "npm publish --tag beta --access public",
    "publish:latest": "npm publish --tag latest --access public"
  },
  "dependencies": {
    "fs-extra": "^11.3.4",
    "jsonc-parser": "^3.3.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "rollup-plugin-copy": "^3.5.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
